<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIFE.CAL"
            android:textColor="#444444"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp"/>

        <!-- Badge -->
        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:textColor="#FF6B00"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="20dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minimalist wallpapers for mindful living."
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="8dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Visualize your year at a glance.\nUpdates automatically on your lock screen."
            android:textColor="#555555"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="32dp"/>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvDaysElapsed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="days elapsed"
                    android:textColor="#555555"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvPercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FF6B00"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="complete"
                    android:textColor="#555555"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView
                    android:id="@+id/tvDaysLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="days left"
                    android:textColor="#555555"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Progress Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="JAN 1"
                    android:textColor="#444444"
                    android:textSize="10sp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TODAY"
                    android:gravity="center"
                    android:textColor="#FF6B00"
                    android:textSize="10sp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DEC 31"
                    android:gravity="end"
                    android:textColor="#444444"
                    android:textSize="10sp"/>
            </LinearLayout>
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:progressDrawable="@drawable/progress_drawable"
                android:max="100"/>
        </LinearLayout>

        <!-- Year Calendar Card -->
        <LinearLayout
            android:id="@+id/cardYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YEAR CALENDAR"
                android:textColor="#444444"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track every day of the year"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="White = past  ·  Orange = today  ·  Grey = future"
                android:textColor="#555555"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"/>

            <ImageView
                android:id="@+id/ivYearPreview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to set as wallpaper →"
                android:textColor="#FF6B00"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Life Calendar Card -->
        <LinearLayout
            android:id="@+id/cardLife"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIFE CALENDAR"
                android:textColor="#444444"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visualize your life in weeks"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="White = lived  ·  Orange = now  ·  Grey = ahead"
                android:textColor="#555555"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"/>

            <ImageView
                android:id="@+id/ivLifePreview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to enter your details →"
                android:textColor="#FF6B00"
                android:textSize="13sp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>